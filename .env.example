# ─────────────────────────────────────────────────────────────────────────────
# BI Monthly Report Agent – Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 3000)
PORT=3000

# ── GitHub ────────────────────────────────────────────────────────────────────
# A GitHub personal access token (or GitHub App installation token) used to
# verify incoming Copilot Extension request signatures.
# Required scope: (none — only used for key verification, not data access)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Azure AD / Microsoft Identity ─────────────────────────────────────────────
# The Azure AD tenant ID for your organisation.
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# The client (application) ID of your Azure AD app registration.
# The app must be granted the "Notes.Read.All" *application* permission.
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# A client secret created for the app registration above.
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OneNote ───────────────────────────────────────────────────────────────────
# The UPN (email) or object ID of the user whose OneNote is being accessed.
# Example: bi-team@yourorg.onmicrosoft.com
ONENOTE_USER_ID=bi-team@yourorg.onmicrosoft.com

# The exact display name of the OneNote notebook containing meeting notes.
# Example: BI Team Notebook
ONENOTE_NOTEBOOK_NAME=BI Team Notebook

# The exact display name of the section within that notebook.
# Example: Meeting Notes
ONENOTE_SECTION_NAME=Meeting Notes
