{
  "name": "bi-monthly-report-agent",
  "version": "1.0.0",
  "description": "GitHub Copilot Extension that generates summarized BI Team monthly reports for leadership from OneNote meeting notes",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "report": "node dist/cli.js run",
    "rerender": "node dist/cli.js rerender",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "copilot-extension",
    "github-copilot",
    "onenote",
    "bi-reporting",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@azure/msal-node-extensions": "^5.2.2",
    "@copilot-extensions/preview-sdk": "^5.0.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "node-html-markdown": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
